{
  "name": "@myrialabs/clopen",
  "version": "0.4.12",
  "description": "All-in-one web workspace for AI coding agents — Claude Code, OpenCode, Codex, Copilot, and Qwen Code — with chat, terminal, git, browser preview, database client, checkpoints, and real-time collaboration",
  "author": "Myria Labs",
  "license": "MIT",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "clopen": "./bin/clopen.ts"
  },
  "main": "./bin/clopen.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/myrialabs/clopen.git"
  },
  "homepage": "https://clopen.myrialabs.dev",
  "bugs": {
    "url": "https://github.com/myrialabs/clopen/issues"
  },
  "keywords": [
    "claude",
    "claude-code",
    "opencode",
    "codex",
    "copilot",
    "qwen-code",
    "ai",
    "assistant",
    "web-ui",
    "bun",
    "svelte",
    "puppeteer",
    "collaboration",
    "terminal",
    "browser-preview",
    "file-management",
    "file-editor",
    "git",
    "source-control",
    "multi-account",
    "anthropic",
    "checkpoint",
    "workspace",
    "cloudflare-tunnel",
    "mcp"
  ],
  "files": [
    "bin",
    "backend",
    "scripts/start.ts",
    "shared",
    "dist",
    "tsconfig.json",
    ".env.example"
  ],
  "engines": {
    "bun": ">=1.2.12"
  },
  "scripts": {
    "dev": "bun scripts/dev.ts",
    "dev:backend": "bun --watch backend/index.ts",
    "dev:frontend": "bunx vite dev",
    "build": "vite build",
    "start": "bun scripts/start.ts",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "bun test --isolate",
    "generate-icons": "bun scripts/generate-icons.ts",
    "prepublishOnly": "bun run build"
  },
  "devDependencies": {
    "@eslint/js": "^9.31.0",
    "@sveltejs/vite-plugin-svelte": "^6.0.0",
    "@tailwindcss/vite": "^4.1.11",
    "@types/bun": "^1.2.18",
    "@types/dompurify": "^3.2.0",
    "@types/node": "^24.0.14",
    "@types/qrcode": "^1.5.6",
    "@types/random-useragent": "^0.3.3",
    "@types/ssh2": "^1.15.5",
    "concurrently": "^9.2.1",
    "eslint": "^9.31.0",
    "eslint-plugin-svelte": "^3.10.1",
    "globals": "^16.3.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "tailwindcss": "^4.1.11",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.37.0",
    "vite": "^7.0.4"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.3.158",
    "@anthropic-ai/sdk": "0.100.1",
    "@elysiajs/cors": "1.4.1",
    "@github/copilot-sdk": "1.0.0-beta.9",
    "@iconify-json/lucide": "1.2.96",
    "@iconify-json/material-icon-theme": "1.2.55",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@monaco-editor/loader": "1.7.0",
    "@myrialabs/ptykit": "0.0.5",
    "@myrialabs/tunnelkit": "0.0.15",
    "@myrialabs/zipkit": "0.0.11",
    "@openai/codex-sdk": "0.135.0",
    "@opencode-ai/sdk": "1.15.12",
    "@qwen-code/sdk": "0.1.7",
    "@sinclair/typebox": "0.34.48",
    "bson": "7.2.0",
    "bun-pty": "0.4.8",
    "dompurify": "3.4.9",
    "elysia": "1.4.27",
    "file-type": "21.3.1",
    "is-text-path": "3.0.0",
    "marked": "16.4.2",
    "monaco-editor": "0.52.2",
    "mongodb": "7.2.0",
    "nanoid": "5.1.6",
    "puppeteer": "24.38.0",
    "puppeteer-extra": "3.3.6",
    "puppeteer-extra-plugin-stealth": "2.11.2",
    "qrcode": "1.5.4",
    "sharp": "0.34.5",
    "ssh2": "1.17.0"
  },
  "trustedDependencies": [
    "puppeteer",
    "sharp"
  ],
  "overrides": {
    "bson": "7.2.0"
  }
